# Copy to `.env` for local development. No secrets here — local-only credentials.

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://storytelly:storytelly@localhost:5432/storytelly

# S3-compatible storage (MinIO locally)
# When deploying to AWS, leave S3_ENDPOINT empty and set S3_FORCE_PATH_STYLE=false.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=storytelly
S3_SECRET_KEY=storytelly-secret
S3_BUCKET=storytelly
S3_FORCE_PATH_STYLE=true
